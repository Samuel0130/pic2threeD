# 在 Vercel 项目 Settings → Environment Variables 中配置同名变量

# Tripo OpenAPI Key（必填）
TRIPO_API_KEY=

# Tripo Client ID（可选，请求头 X-Client-Id）
TRIPO_CLIENT_ID=

# 可选：模型版本，默认 v2.5-20250123（见官方文档）
# TRIPO_MODEL_VERSION=v2.5-20250123

# 可选：国内等线路，例如 rg2（见 Tripo 文档）
# TRIPO_REGION=rg2

# 可选：OpenAPI 根地址，默认 https://api.tripo3d.ai/v2/openapi
# TRIPO_OPENAPI_BASE=https://api.tripo3d.ai/v2/openapi
